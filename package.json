{
  "name": "pixel-serve-server",
  "version": "2.8.7",
  "description": "A robust Node.js utility for handling and processing images. This package provides features like resizing, format conversion and etc.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./assets/*": "./dist/assets/*",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "check-types-pack": "attw --pack .",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "format": "prettier --check \"src/**/*.{ts,tsx}\"",
    "test": "vitest run --coverage",
    "test:watch": "vitest watch",
    "type-check": "tsc --noEmit",
    "verify": "node scripts/verify.mjs",
    "branch": "node scripts/new-branch.mjs",
    "sync": "node scripts/sync-main.mjs",
    "release:prepare": "node scripts/release-prepare.mjs",
    "release:tag": "node scripts/release-tag.mjs"
  },
  "files": [
    "dist",
    "dist/assets",
    "SECURITY.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hiprax/pixel-serve-server.git"
  },
  "keywords": [
    "Pixel Serve",
    "Image",
    "Image Serving",
    "Image Optimization",
    "Image Resizing",
    "Image Formatting",
    "Image Transformation"
  ],
  "author": "Hiprax",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Hiprax/pixel-serve-server/issues"
  },
  "homepage": "https://github.com/Hiprax/pixel-serve-server#readme",
  "dependencies": {
    "axios": "^1.13.2",
    "express": "^5.2.1",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.7.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20"
  }
}
